<Page x:Class="EbookLibraryUI.Views.EbookDetailView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Edit Ebook"
      Background="{StaticResource SurfaceBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Edit Ebook"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Cover + error flag -->
            <StackPanel Grid.Column="0">
                <Border Width="130" Height="182"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Background="White"
                        ClipToBounds="True"
                        Cursor="Hand"
                        ToolTip="Click to preview original size"
                        MouseLeftButtonUp="CoverBorder_OnMouseLeftButtonUp">
                    <Image x:Name="CoverImage"
                           Source="{Binding CoverUrl}"
                           Stretch="UniformToFill" />
                </Border>

                <CheckBox Content="Has errors"
                          IsChecked="{Binding HasErrors}"
                          Margin="0,12,0,0" />
            </StackPanel>

            <!-- Form fields -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Title" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" FontSize="13" />

                    <TextBlock Text="Authors (comma-separated)" Style="{StaticResource FieldLabelStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding AuthorsText, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" />
                        <Button Grid.Column="1"
                                Content="Find again"
                                Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenFindAgainCommand}"
                                CommandParameter="authors" />
                    </Grid>

                    <!-- ISBN, Year, Language, Edition, Page count — single row -->
                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="176" MaxWidth="268" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" MinWidth="148" MaxWidth="220" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" MinWidth="64" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" MinWidth="64" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="Auto" MinWidth="88" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="ISBN" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="148" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Isbn, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="20"
                                         Padding="8,6" FontSize="13" />
                                <Button Grid.Column="1"
                                        Content="Find again"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding OpenFindAgainCommand}"
                                        CommandParameter="isbn" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Year" Style="{StaticResource FieldLabelStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="76" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}"
                                         MinWidth="72"
                                         Padding="8,6" FontSize="13" />
                                <Button Grid.Column="1"
                                        Content="Find again"
                                        Margin="8,0,0,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding OpenFindAgainCommand}"
                                        CommandParameter="year" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="4">
                            <TextBlock Text="Language" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding Language, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,6" FontSize="13" />
                        </StackPanel>

                        <StackPanel Grid.Column="6">
                            <TextBlock Text="Edition" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding Edition, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,6" FontSize="13" />
                        </StackPanel>

                        <StackPanel Grid.Column="8">
                            <TextBlock Text="Page count" Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding PageCount, UpdateSourceTrigger=PropertyChanged}"
                                     MinWidth="80"
                                     Padding="8,6" FontSize="13" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" FontSize="13" />

                    <TextBlock Text="Subcategory" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding Subcategory, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" FontSize="13" />

                    <TextBlock Text="Tags" Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Text="Keywords about this book (comma-separated). Not limited to category."
                               Foreground="{StaticResource SubtleTextBrush}"
                               FontSize="11"
                               Margin="0,0,0,4"
                               TextWrapping="Wrap" />
                    <TextBox Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6" FontSize="13"
                             AcceptsReturn="False"
                             ToolTip="Example: C#, SOLID Principles, Design Patterns" />

                    <TextBlock Text="Publisher" Style="{StaticResource FieldLabelStyle}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding Publisher, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="8,6" FontSize="13" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Margin="8,0,0,0">
                            <Button Content="Add to catalog"
                                    ToolTip="Saves this imprint to the library catalog for faster matching on new books"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding AddPublisherToCatalogCommand}" />
                            <Button Content="Find again"
                                    Margin="8,0,0,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding OpenFindAgainCommand}"
                                    CommandParameter="publisher" />
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="90"
                             VerticalScrollBarVisibility="Auto"
                             Padding="8,6" FontSize="13" />

                    <!-- Action buttons -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button Content="💾  Save"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding SaveCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="✕  Cancel"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelCommand}" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Margin="0,8,0,16" />

                    <Border Background="#AA000000"
                            Visibility="{Binding IsFindAgainDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="360">
                            <Border Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Find again" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="Page range (1-based inclusive)"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <TextBox Text="{Binding FindAgainPageRange, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="8,6"
                                             FontSize="13" />

                                    <TextBlock Text="Direction" Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox SelectedValue="{Binding FindAgainDirection, UpdateSourceTrigger=PropertyChanged}"
                                              SelectedValuePath="Tag">
                                        <ComboBoxItem Content="Front to Back" Tag="front_to_back" />
                                        <ComboBoxItem Content="Back to Front" Tag="back_to_front" />
                                    </ComboBox>

                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                        <Button Content="Run"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Command="{Binding RunFindAgainCommand}" />
                                        <Button Content="Cancel"
                                                Margin="8,0,0,0"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding CloseFindAgainCommand}" />
                                    </StackPanel>

                                    <TextBlock Text="Running..."
                                               Margin="0,8,0,0"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Visibility="{Binding IsReextracting, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
