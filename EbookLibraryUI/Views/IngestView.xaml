<Page x:Class="EbookLibraryUI.Views.IngestView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ingest"
      Background="{StaticResource SurfaceBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Page heading -->
        <TextBlock Grid.Row="0"
                   Text="Ingest Ebooks"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <!-- Input card -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Folder path" Style="{StaticResource FieldLabelStyle}" Margin="0,0,0,4" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SelectedPath, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,6"
                             FontSize="13"
                             Margin="0,0,8,0"
                             VerticalContentAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Browse…"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseFolderCommand}" />
                </Grid>

                <TextBlock Text="Cover image path" Style="{StaticResource FieldLabelStyle}" Margin="0,10,0,4" />
                <TextBox Text="{Binding CoverImagePath, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6"
                         FontSize="13" />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock Text="File type:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox ItemsSource="{Binding Extensions}"
                              SelectedItem="{Binding SelectedExtension}"
                              Width="80"
                              Margin="0,0,20,0" />

                    <Button Content="▶  Start Ingestion"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding StartIngestCommand}"
                            Margin="0,0,8,0" />

                    <Button Content="■  Cancel"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CancelIngestCommand}"
                            IsEnabled="{Binding IsIngesting}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Progress heading + spinner -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Progress"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <ProgressBar IsIndeterminate="True"
                         Width="100" Height="4"
                         Margin="12,0,0,0"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsIngesting, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!-- Scrolling log -->
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Background="White">
            <ScrollViewer x:Name="ProgressScroller"
                          VerticalScrollBarVisibility="Auto"
                          Padding="8">
                <ItemsControl ItemsSource="{Binding ProgressLog}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource SubtleTextBrush}"
                   Margin="0,8,0,0" />
    </Grid>
</Page>
