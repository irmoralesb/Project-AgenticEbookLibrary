<Page x:Class="EbookLibraryUI.Views.LibraryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:EbookLibraryUI.ViewModels"
      Title="Library"
      Background="{StaticResource SurfaceBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    Margin="0,0,0,12" VerticalAlignment="Center">
            <TextBlock Text="Library"
                       FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0" />
            <CheckBox Content="Batch update"
                      IsChecked="{Binding IsBatchUpdateMode, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,0,16,0" />
            <Button Command="{Binding OpenBatchReextractDialogCommand}"
                    Margin="0,0,12,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                        <Setter Property="Content" Value="Re-extract selected…" />
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBatchUpdateMode}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBatchRunning}" Value="True">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="⟳  Refresh"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding LoadBooksCommand}"
                    Margin="0,0,12,0" />
            <ProgressBar IsIndeterminate="True"
                         Width="100" Height="4"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsLibraryBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!-- Filters -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="12,10"
                Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filter by"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0" />
                <TextBlock Text="Publisher"
                           Style="{StaticResource FieldLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Width="200"
                         MinHeight="26"
                         VerticalContentAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="0,0,20,0"
                         Text="{Binding PublisherFilterText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Category"
                           Style="{StaticResource FieldLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Width="180"
                         MinHeight="26"
                         VerticalContentAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="0,0,20,0"
                         Text="{Binding CategoryFilterText, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Text="Tags"
                           Style="{StaticResource FieldLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox Width="160"
                         MinHeight="26"
                         VerticalContentAlignment="Center"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"
                         IsEnabled="{Binding IsTagsTextFilterEnabled}"
                         ToolTip="Match any tag containing this text (case-insensitive)"
                         Text="{Binding TagsFilterText, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Content="No tags"
                          VerticalAlignment="Center"
                          Margin="0,0,20,0"
                          ToolTip="Show only books with no tags"
                          IsChecked="{Binding TagsEmptyOnly, Mode=TwoWay}" />
                <TextBlock Text="Has error"
                           Style="{StaticResource FieldLabelStyle}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <ComboBox Width="130"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"
                          SelectedValue="{Binding ErrorFilter, Mode=TwoWay}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="All" Tag="{x:Static vm:LibraryErrorFilter.All}" />
                    <ComboBoxItem Content="Has error" Tag="{x:Static vm:LibraryErrorFilter.HasErrorsOnly}" />
                    <ComboBoxItem Content="No error" Tag="{x:Static vm:LibraryErrorFilter.NoErrorsOnly}" />
                </ComboBox>
                <Button Content="Apply filter"
                        Style="{StaticResource SecondaryButtonStyle}"
                        VerticalAlignment="Center"
                        Command="{Binding ApplyFilterCommand}" />
            </StackPanel>
        </Border>

        <!-- Book grid -->
        <DataGrid x:Name="BookGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Books}"
                  SelectedItem="{Binding SelectedBook}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  ToolTip="Double-click a row to open with your default reader."
                  MouseDoubleClick="BookGrid_OnMouseDoubleClick">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="BorderThickness" Value="0" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Book.HasErrors}" Value="True">
                            <Setter Property="BorderBrush" Value="#FFF5A8A8" />
                            <Setter Property="BorderThickness" Value="2" />
                            <Setter Property="Background" Value="#12E53935" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <DataGridTemplateColumn Width="40" CanUserSort="False">
                    <DataGridTemplateColumn.HeaderTemplate>
                        <DataTemplate>
                            <CheckBox HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Visibility="{Binding DataContext.IsBatchUpdateMode, RelativeSource={RelativeSource AncestorType=DataGrid}, Converter={StaticResource BoolToVisibilityConverter}}"
                                      Command="{Binding DataContext.ToggleSelectAllVisibleCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                      ToolTip="Select all visible" />
                        </DataTemplate>
                    </DataGridTemplateColumn.HeaderTemplate>
                    <DataGridTemplateColumn.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.IsBatchUpdateMode, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTemplateColumn.CellStyle>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsBatchSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Cover thumbnail -->
                <DataGridTemplateColumn Header="" Width="64" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding Book.CoverUrl}"
                                   Width="40" Height="56"
                                   Stretch="UniformToFill"
                                   Margin="4,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Error flag -->
                <DataGridTemplateColumn Header="" Width="32" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="🚩"
                                       FontSize="15"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource DangerBrush}"
                                       ToolTip="Marked with processing errors (has_errors)"
                                       Visibility="{Binding Book.HasErrors, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Title"      Binding="{Binding Book.Title}"          Width="2*" />
                <DataGridTextColumn Header="Authors"    Binding="{Binding Book.AuthorsDisplay}"  Width="*" />
                <DataGridTextColumn Header="Category"   Binding="{Binding Book.Category}"        Width="130" />
                <DataGridTextColumn Header="Tags"       Binding="{Binding Book.TagsDisplay}"     Width="*" />
                <DataGridTextColumn Header="Year"       Binding="{Binding Book.Year}"            Width="55" />
                <DataGridTextColumn Header="Publisher"  Binding="{Binding Book.Publisher}"       Width="110" />
                <DataGridTextColumn Header="Pages"      Binding="{Binding Book.PageCount}"       Width="55" />

                <!-- Action column -->
                <DataGridTemplateColumn Header="" Width="90" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Content="✏"
                                        ToolTip="Edit"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="14"
                                        Margin="2"
                                        Command="{Binding DataContext.EditBookCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="🗑"
                                        ToolTip="Delete"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="14"
                                        Foreground="{StaticResource DangerBrush}"
                                        Margin="2"
                                        Command="{Binding DataContext.DeleteBookCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Batch progress log -->
        <Border Grid.Row="3"
                Margin="0,8,0,0"
                Padding="8"
                MaxHeight="160"
                Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Visibility="{Binding ShowBatchProgressPanel, Converter={StaticResource BoolToVisibilityConverter}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ProgressLog}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,1" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Status bar -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource SubtleTextBrush}"
                   Margin="0,8,0,0" />

        <!-- Batch dialog overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="#66000000"
                Visibility="{Binding BatchDialogOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="20">
            <Border VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="20"
                    MinWidth="360">
                <StackPanel>
                    <TextBlock Text="Batch re-extract"
                               FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="Re-extract and save one field for all checked rows."
                               Margin="0,8,0,12"
                               Foreground="{StaticResource SubtleTextBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Field" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox Margin="0,0,0,10"
                              SelectedValue="{Binding BatchField, Mode=TwoWay}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="Authors" Tag="authors" />
                        <ComboBoxItem Content="ISBN" Tag="isbn" />
                        <ComboBoxItem Content="Publisher" Tag="publisher" />
                        <ComboBoxItem Content="Year" Tag="year" />
                        <ComboBoxItem Content="Tags" Tag="tags" />
                    </ComboBox>

                    <TextBlock Text="Page range" Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Margin="0,0,0,10"
                             Text="{Binding BatchPageRange, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Direction" Style="{StaticResource FieldLabelStyle}" />
                    <ComboBox Margin="0,0,0,16"
                              SelectedValue="{Binding BatchDirection, Mode=TwoWay}"
                              SelectedValuePath="Tag">
                        <ComboBoxItem Content="Front to Back" Tag="front_to_back" />
                        <ComboBoxItem Content="Back to Front" Tag="back_to_front" />
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Run"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding RunBatchReextractCommand}"
                                Margin="0,0,8,0" />
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CancelBatchDialogCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
