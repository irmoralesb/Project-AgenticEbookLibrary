<Page x:Class="EbookLibraryUI.Views.LibraryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Library"
      Background="{StaticResource SurfaceBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    Margin="0,0,0,12" VerticalAlignment="Center">
            <TextBlock Text="Library"
                       FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="0,0,20,0" />
            <Button Content="⟳  Refresh"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding LoadBooksCommand}"
                    Margin="0,0,12,0" />
            <ProgressBar IsIndeterminate="True"
                         Width="100" Height="4"
                         VerticalAlignment="Center"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <!-- Book grid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Books}"
                  SelectedItem="{Binding SelectedBook}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="White"
                  RowBackground="White"
                  AlternatingRowBackground="#FAFAFA"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1">

            <DataGrid.Columns>

                <!-- Cover thumbnail -->
                <DataGridTemplateColumn Header="" Width="64" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding CoverUrl}"
                                   Width="40" Height="56"
                                   Stretch="UniformToFill"
                                   Margin="4,2" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Title"      Binding="{Binding Title}"          Width="2*" />
                <DataGridTextColumn Header="Authors"    Binding="{Binding AuthorsDisplay}"  Width="*" />
                <DataGridTextColumn Header="Category"   Binding="{Binding Category}"        Width="130" />
                <DataGridTextColumn Header="Year"       Binding="{Binding Year}"            Width="55" />
                <DataGridTextColumn Header="Publisher"  Binding="{Binding Publisher}"       Width="110" />
                <DataGridTextColumn Header="Pages"      Binding="{Binding PageCount}"       Width="55" />

                <!-- Action column -->
                <DataGridTemplateColumn Header="" Width="90" CanUserSort="False">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Button Content="✏"
                                        ToolTip="Edit"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="14"
                                        Margin="2"
                                        Command="{Binding DataContext.EditBookCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                                <Button Content="🗑"
                                        ToolTip="Delete"
                                        Style="{StaticResource IconButtonStyle}"
                                        FontSize="14"
                                        Foreground="{StaticResource DangerBrush}"
                                        Margin="2"
                                        Command="{Binding DataContext.DeleteBookCommand,
                                            RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="{StaticResource SubtleTextBrush}"
                   Margin="0,8,0,0" />
    </Grid>
</Page>
