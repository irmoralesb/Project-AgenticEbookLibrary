<Page x:Class="EbookLibraryUI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings"
      Background="{StaticResource SurfaceBrush}">

    <Grid Margin="20">
        <StackPanel MaxWidth="480">
            <TextBlock Text="Settings"
                       FontSize="20" FontWeight="SemiBold"
                       Margin="0,0,0,16" />
            <Border Style="{StaticResource CardStyle}">
                <TextBlock TextWrapping="Wrap"
                           Margin="16"
                           Text="Cover images are extracted next to each ebook file as a matching .png (for example MyBook.pdf → MyBook.png). Nothing needs to be configured here." />
            </Border>
        </StackPanel>
    </Grid>
</Page>
