<Window x:Class="EbookLibraryUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:EbookLibraryUI.Views"
        Title="Agentic Ebook Library"
        Height="760" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource SurfaceBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Navigation rail -->
            <ColumnDefinition Width="200" />
            <!-- Separator -->
            <ColumnDefinition Width="1" />
            <!-- Page content -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── Navigation rail ──────────────────────────────── -->
        <Border Grid.Column="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,0">
            <StackPanel Margin="0,8">

                <!-- App title -->
                <TextBlock Text="Ebook Library"
                           FontSize="16" FontWeight="SemiBold"
                           Margin="16,12,16,20" />

                <Button x:Name="NavLibraryButton"
                        Content="📚  Library"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        FontSize="14"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="NavLibrary_Click" />

                <Button x:Name="NavIngestButton"
                        Content="⬇  Ingest"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        FontSize="14"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="NavIngest_Click" />

                <Button x:Name="NavSettingsButton"
                        Content="⚙  Settings"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Padding="16,10"
                        FontSize="14"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="NavSettings_Click" />
            </StackPanel>
        </Border>

        <!-- Vertical separator -->
        <Rectangle Grid.Column="1"
                   Fill="{StaticResource BorderBrush}" />

        <!-- ── Page frame ────────────────────────────────────── -->
        <Frame x:Name="PageFrame"
               Grid.Column="2"
               NavigationUIVisibility="Hidden"
               Background="{StaticResource SurfaceBrush}" />
    </Grid>
</Window>
